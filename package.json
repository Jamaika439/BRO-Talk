{
  "name": "bro-talk",
  "version": "4.2.0",
  "description": "Bro Talk Messenger",
  "author": "TestName4",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.1",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.2"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.9.1"
  },
  "build": {
    "appId": "com.brotalk.app",
    "productName": "Bro Talk",
    "win": {
      "target": "nsis",
      "requestedExecutionLevel": "asInvoker",
      "icon": "assets/icon.ico",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "files": [
      "main.js",
      "server.js",
      "preload.js",
      "index.html",
      "noise-gate-processor.js",
      "assets/**",
      "node_modules/**"
    ],
    "extraResources": [
      {
        "from": "data/",
        "to": "data/"
      },
      {
        "from": "server.js",
        "to": "server.js"
      },
      {
        "from": "noise-gate-processor.js",
        "to": "noise-gate-processor.js"
      }
    ],
    "asarUnpack": [
      "server.js",
      "noise-gate-processor.js",
      "node_modules/express/**",
      "node_modules/socket.io/**",
      "node_modules/multer/**"
    ]
  }
}
